# EXPRESS BACKEND ENVIRONMENT VARIABLES
# Copy this file to .env and fill in the values.

# Port for the Express server
PORT=3001

# Allowed origin for CORS (Frontend URL)
FRONTEND_URL=http://localhost:3000

# Supabase Credentials (for DB connection, Auth verification, and Admin rights)
SUPABASE_URL=your-supabase-project-url
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Anthropic Claude API Key (for the workers)
ANTHROPIC_API_KEY=sk-ant-api03-...

# Stripe Secret Key (for subscriptions and webhooks)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend API Key (for newsletter emailing)
RESEND_API_KEY=re_...
# Variables d'environnement pour Railway

# Port de l'application
PORT=3001

# URL du frontend autorisé (ici votre app Vercel)
FRONTEND_URL=https://votre-frontend-vercel.vercel.app

# Clés Supabase (obligatoires pour le backend)
SUPABASE_URL=votre_url_supabase
SUPABASE_ANON_KEY=votre_cle_publique_supabase
SUPABASE_SERVICE_KEY=votre_cle_privee_supabase
